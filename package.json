{
  "name": "doughnut-impact-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash ./scripts/with-node20.sh npx next dev",
    "build": "bash ./scripts/with-node20.sh npx next build",
    "start": "bash ./scripts/with-node20.sh npx next start",
    "lint": "bash ./scripts/with-node20.sh npx next lint",
    "test": "bash ./scripts/with-node20.sh npx vitest run",
    "test:watch": "bash ./scripts/with-node20.sh npx vitest",
    "prisma:generate": "bash ./scripts/with-node20.sh npx prisma generate",
    "prisma:migrate": "bash ./scripts/with-node20.sh npx prisma migrate dev",
    "prisma:seed": "bash ./scripts/with-node20.sh npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@inngest/agent-kit": "^0.11.0",
    "@prisma/client": "^5.20.0",
    "@tanstack/react-query": "^5.59.15",
    "d3": "^7.9.0",
    "inngest": "^3.31.8",
    "next": "14.2.16",
    "openai": "^4.71.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.53.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
